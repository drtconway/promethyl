// promethyl cohort pipeline — Nextflow config

conda.enabled = true

// Points at a pre-built conda env by name/path, defaulting to envs/promethyl under
// PROMETHYL_HOME (or projectDir if that's not set) — e.g. a shared install built once
// with `conda env create -f promethyl_environment.yml -p $PROMETHYL_HOME/envs/promethyl`.
// Override with --conda_env to point elsewhere (e.g. --conda_env promethyl_environment.yml
// to solve the env on the fly instead of using a pre-built one).
params.conda_env = "${System.getenv('PROMETHYL_HOME') ?: projectDir}/envs/promethyl"

process {
    conda = params.conda_env

    withName: CHECK_MM_TAGS {
        queue  = 'prod_med'
        time   = 4.h
    }
    withName: MODKIT {
        cpus   = { params.threads }
        memory = 4.GB
        queue  = 'prod_short'
        time   = 1.h
    }
    withName: COHORT {
        cpus   = 1
        memory = 32.GB
        queue  = 'prod_short'
        time   = 2.h
    }
}

env {
    PYTHONPATH = "${projectDir}/src"
}

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'prod_short'
    }
}

report {
    enabled   = true
    file      = 'report.html'
    overwrite = true
}

// scripts in src/ are invoked directly on PATH in main.nf (e.g. run_sample.py);
// this puts src/ on PATH for every process so those calls resolve.
process.beforeScript = "export PATH=\"${projectDir}/src:\$PATH\""
