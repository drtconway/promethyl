// promethyl cohort pipeline — Nextflow config

conda.enabled = true

// Points at a pre-built conda env by name/path (e.g. a shared install built once with
// `conda env create -f promethyl_environment.yml -p /shared/path/envs/promethyl`).
// Falls back to solving promethyl_environment.yml on the fly, which is fine for local
// use but should be avoided on compute nodes without internet/channel access.
params.conda_env = null

process {
    conda = params.conda_env ?: "${projectDir}/promethyl_environment.yml"

    withName: MODKIT {
        cpus   = { params.threads }
        memory = '4 GB'
        time   = '1h'
    }
    withName: COHORT {
        cpus   = 1
        memory = '32 GB'
        time   = '2h'
    }
}

env {
    PYTHONPATH = "${projectDir}/src"
}

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'prod_short'
    }
}

// scripts in src/ are invoked directly on PATH in main.nf (e.g. run_sample.py);
// this puts src/ on PATH for every process so those calls resolve.
process.beforeScript = "export PATH=\"${projectDir}/src:\$PATH\""
